# Copiar a .env y ajustar. No commitear .env.
# docker compose carga .env automaticamente.

# --- Puertos (cambiar si hay conflictos en el servidor) ---
MQTT_PORT=1883
WEB_UI_PORT=8080

# --- SSL / Let's Encrypt (solo para producción con HTTPS) ---
# Dominio apuntando a la IP pública de este servidor
DOMAIN=hidroponia.ejemplo.com
# Email para notificaciones de Let's Encrypt (expiración de cert)
SSL_EMAIL=tu-email@ejemplo.com
