# cp .env.example .env  (no commitear .env)
#
# OBLIGATORIO antes de "docker compose up": crear el fichero passwd (no una carpeta):
#   ./scripts/gen-mqtt-passwd.sh hidro_mqtt 'TuClaveSegura'
#
# Si falló un "up" sin passwd, Docker pudo crear ./mosquitto/config/passwd como directorio.
# Solución: docker compose down && rm -rf mosquitto/config/passwd && ./scripts/gen-mqtt-passwd.sh ...

MQTT_PORT=1883
MQTT_WS_PORT=9001
WEB_UI_PORT=8080
